<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 注意：必须和 ResumeMapper.java 全限定名一致 -->
<mapper namespace="com.aiinterview.mapper.ResumerMapper">

    <!-- 通用结果映射（解决 fullName / userId 等 setter 报错） -->
    <resultMap id="BaseResultMap" type="com.aiinterview.model.entity.resumer">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="name" property="name"/>
        <result column="full_name" property="fullName"/>
        <result column="phone" property="phone"/>
        <result column="email" property="email"/>
        <result column="avatar_url" property="avatarUrl"/>
        <result column="position" property="position"/>
        <result column="work_years" property="workYears"/>
        <result column="expected_city" property="expectedCity"/>
        <result column="expected_salary_min" property="expectedSalaryMin"/>
        <result column="expected_salary_max" property="expectedSalaryMax"/>
        <result column="expected_industry" property="expectedIndustry"/>
        <result column="profile" property="profile"/>
        <result column="template_id" property="templateId"/>
        <result column="template_type" property="templateType"/>
        <result column="template_config" property="templateConfig"/>
        <result column="is_default" property="isDefault"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="share_code" property="shareCode"/>
        <result column="view_count" property="viewCount"/>
        <result column="download_count" property="downloadCount"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 根据用户ID获取简历列表 -->
    <select id="selectDefaultByUserId" resultType="com.aiinterview.model.entity.resumer">
        SELECT *
        FROM resume
        WHERE user_id = #{userId}
          AND is_default = TRUE
          AND is_deleted = 0
            LIMIT 1
    </select>

    <!-- 根据分享码获取简历 -->
    <select id="selectByShareCode" resultMap="BaseResultMap">
        SELECT *
        FROM resume
        WHERE share_code = #{shareCode}
          AND is_deleted = 0
    </select>

    <!-- 搜索简历 -->
    <select id="searchResumes" resultMap="BaseResultMap">
        SELECT *
        FROM resume
        WHERE is_deleted = 0
        <if test="userId != null">
            AND user_id = #{userId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND (
            name LIKE CONCAT('%', #{keyword}, '%')
            OR full_name LIKE CONCAT('%', #{keyword}, '%')
            OR position LIKE CONCAT('%', #{keyword}, '%')
            OR profile LIKE CONCAT('%', #{keyword}, '%')
            )
        </if>
        ORDER BY updated_at DESC
    </select>

    <!-- 获取热门简历 -->
    <select id="selectPopularResumes" resultMap="BaseResultMap">
        SELECT *
        FROM resume
        WHERE is_deleted = 0
        ORDER BY view_count DESC, updated_at DESC
            LIMIT #{limit}
    </select>

    <!-- 更新查看次数 -->
    <update id="updateViewCount">
        UPDATE resume
        SET view_count = view_count + 1
        WHERE resume_id = #{id}
    </update>

</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiinterview.mapper.SkillMapper">

    <!-- 根据简历ID获取技能列表 -->
    <select id="selectByResumeId" resultType="com.aiinterview.model.entity.Skill">
        SELECT * FROM skill 
        WHERE resume_id = #{resumeId}
        ORDER BY proficiency DESC, skill_name ASC
    </select>

    <!-- 根据简历ID删除技能 -->
    <delete id="deleteByResumeId">
        DELETE FROM skill 
        WHERE resume_id = #{resumeId}
    </delete>

</mapper> 
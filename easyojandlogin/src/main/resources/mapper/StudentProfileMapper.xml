<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace 必须与 Mapper 接口全限定名一致 -->
<mapper namespace="com.aiinterview.mapper.StudentProfileMapper">

    <!-- 通用结果映射-->
    <resultMap id="BaseResultMap"
               type="com.aiinterview.model.entity.student.StudentProfile">
        <id column="student_id" property="studentId"/>
        <result column="user_id" property="userId"/>
        <result column="student_no" property="studentNo"/>
        <result column="real_name" property="realName"/>
        <result column="gender" property="gender"/>
        <result column="college" property="college"/>
        <result column="major" property="major"/>
        <result column="class_name" property="className"/>
        <result column="grade" property="grade"/>
        <result column="education_level" property="educationLevel"/>
        <result column="graduation_year" property="graduationYear"/>
        <result column="profile_completion" property="profileCompletion"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 根据 userId 查询学生档案 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT *
        FROM student_profile
        WHERE user_id = #{userId}
    </select>

    <!-- 插入学生档案 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="studentId">
        INSERT INTO student_profile (
            user_id,
            student_no,
            real_name,
            gender,
            college,
            major,
            class_name,
            grade,
            education_level,
            graduation_year,
            profile_completion,
            created_at,
            updated_at
        ) VALUES (
                     #{userId},
                     #{studentNo},
                     #{realName},
                     #{gender},
                     #{college},
                     #{major},
                     #{className},
                     #{grade},
                     #{educationLevel},
                     #{graduationYear},
                     #{profileCompletion},
                     NOW(),
                     NOW()
                 )
    </insert>

    <!-- 根据 studentId 更新学生档案 -->
    <update id="updateById">
        UPDATE student_profile
        <set>
            <if test="studentNo != null">
                student_no = #{studentNo},
            </if>
            <if test="realName != null">
                real_name = #{realName},
            </if>
            <if test="gender != null">
                gender = #{gender},
            </if>
            <if test="college != null">
                college = #{college},
            </if>
            <if test="major != null">
                major = #{major},
            </if>
            <if test="className != null">
                class_name = #{className},
            </if>
            <if test="grade != null">
                grade = #{grade},
            </if>
            <if test="educationLevel != null">
                education_level = #{educationLevel},
            </if>
            <if test="graduationYear != null">
                graduation_year = #{graduationYear},
            </if>
            <if test="profileCompletion != null">
                profile_completion = #{profileCompletion},
            </if>
            updated_at = NOW()
        </set>
        WHERE student_id = #{studentId}
    </update>

</mapper>
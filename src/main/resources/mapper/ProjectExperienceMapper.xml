<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiinterview.mapper.ProjectExperienceMapper">

    <!-- 根据简历ID获取项目经验列表 -->
    <select id="selectByResumeId" resultType="com.aiinterview.model.entity.ProjectExperience">
        SELECT * FROM project_experience 
        WHERE resume_id = #{resumeId}
        ORDER BY start_date DESC
    </select>

    <!-- 根据简历ID删除项目经验 -->
    <delete id="deleteByResumeId">
        DELETE FROM project_experience 
        WHERE resume_id = #{resumeId}
    </delete>

</mapper> 